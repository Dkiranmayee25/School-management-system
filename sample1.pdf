    <title>Access Portal | Green Valley School</title>
    <link href="https://cloudflare.com" rel="stylesheet">
    <style>
        :root {
            --primary: #1e6091;
            --secondary: #184e77;
            --accent: #52b788;
            --bg-light: #f8fafc;
            --white: #ffffff;
        }

        body, html { margin: 0; padding: 0; font-family: 'Segoe UI', Roboto, sans-serif; height: 100vh; overflow: hidden; background: var(--bg-light); }
        .main-container { display: flex; height: 100vh; }

        /* Left Side: School Info */
        .info-side {
            flex: 1.2;
            background: linear-gradient(135deg, var(--secondary) 0%, var(--primary) 100%);
            color: white;
            padding: 80px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
        }

        /* Subtle background pattern */
        .info-side::before {
            content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background-image: url("https://transparenttextures.com");
            opacity: 0.1; pointer-events: none;
        }

        .school-brand h1 { font-size: 52px; margin: 0; font-weight: 800; letter-spacing: -1px; }
        .school-brand p { font-size: 18px; opacity: 0.9; margin-top: 10px; font-weight: 300; }
        .tagline { margin-top: 20px; font-size: 14px; opacity: 0.6; }

        .feature-list { list-style: none; padding: 0; margin-top: 60px; position: relative; z-index: 1; }
        .feature-list li { margin-bottom: 35px; display: flex; align-items: center; gap: 20px; }
        .feature-list i { 
            background: rgba(255,255,255,0.1); padding: 15px; border-radius: 50%; 
            font-size: 20px; width: 25px; height: 25px; display: flex; align-items: center; justify-content: center;
        }
        .feature-list h4 { margin: 0; font-size: 18px; font-weight: 600; }
        .feature-list p { margin: 5px 0 0 0; opacity: 0.7; font-size: 14px; }

        /* Right Side: Login & Admission */
        .portal-side { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px; position: relative; }
        
        .login-card { background: var(--white); width: 100%; max-width: 400px; padding: 40px; border-radius: 24px; box-shadow: 0 20px 50px rgba(0,0,0,0.05); }
        .login-card h2 { text-align: center; color: var(--secondary); margin-bottom: 30px; font-weight: 700; font-size: 24px; }

        /* Role Switcher */
        .role-selector { display: flex; background: #f1f5f9; padding: 5px; border-radius: 12px; margin-bottom: 30px; }
        .role-btn { 
            flex: 1; border: none; padding: 12px; border-radius: 10px; cursor: pointer; 
            font-weight: 600; color: #64748b; background: transparent; transition: 0.3s; 
        }
        .role-btn.active { background: var(--primary); color: white; box-shadow: 0 4px 12px rgba(30, 96, 145, 0.2); }

        /* Form */
        .input-group { margin-bottom: 20px; }
        .input-group label { display: block; font-size: 13px; font-weight: 600; color: #475569; margin-bottom: 8px; }
        .input-group input { 
            width: 100%; padding: 14px 16px; border: 1px solid #e2e8f0; border-radius: 12px; 
            box-sizing: border-box; outline: none; transition: 0.3s; background: #f8fafc;
        }
        .input-group input:focus { border-color: var(--primary); background: white; box-shadow: 0 0 0 4px rgba(30, 96, 145, 0.05); }

        .btn-login { 
            width: 100%; padding: 16px; background: var(--accent); color: white; border: none; 
            border-radius: 12px; font-size: 16px; font-weight: 700; cursor: pointer; transition: 0.3s;
        }
        .btn-login:hover { background: #3fa373; transform: translateY(-2px); box-shadow: 0 10px 20px rgba(82, 183, 136, 0.2); }

        /* Admission Section - Fixed Alignment */
        .admission-box { 
            margin-top: 30px; padding: 25px; background: white; border-radius: 20px; 
            width: 100%; max-width: 350px; text-align: center; box-shadow: 0 10px 25px rgba(0,0,0,0.03);
            border: 1px solid #f1f5f9;
        }
        .admission-box p { font-size: 13px; color: #64748b; margin-bottom: 15px; }
        .btn-apply { 
            display: inline-block; width: 100%; padding: 12px; border: 2px solid var(--primary); 
            color: var(--primary); text-decoration: none; border-radius: 10px; font-weight: 700; font-size: 14px; transition: 0.3s;
        }
        .btn-apply:hover { background: var(--primary); color: white; }

        @media (max-width: 1024px) { .info-side { display: none; } }
    </style>
</head>
<body>

<div class="main-container">
    <div class="info-side">
        <div class="school-brand">
            <h1>Green Valley School</h1>
            <p>Knowledge | Discipline | Excellence</p>
            <div class="tagline">Shaping bright futures since 2005.</div>
        </div>
        
        <ul class="feature-list">
            <li><i class="fas fa-user-tie"></i><div><h4>Qualified Teachers</h4><p>Highly experienced and dedicated academic staff.</p></div></li>
            <li><i class="fas fa-atom"></i><div><h4>Modern Infrastructure</h4><p>Robotics, science, and high-speed computer labs.</p></div></li>
            <li><i class="fas fa-swimmer"></i><div><h4>Sports & Arts</h4><p>Comprehensive training for physical and creative growth.</p></div></li>
        </ul>
    </div>

    <div class="portal-side">
        <div class="login-card">
            <h2>Access Portal</h2>
            
            <form action="login.php" method="POST">
                <div class="role-selector">
                    <button type="button" class="role-btn" onclick="setRole(this, 'admin')">Admin</button>
                    <button type="button" class="role-btn" onclick="setRole(this, 'teacher')">Teacher</button>
                    <button type="button" class="role-btn active" onclick="setRole(this, 'student')">Student</button>
                </div>

                <input type="hidden" name="user_type" id="user_type_hidden" value="student">

                <div class="input-group">
                    <label id="user-label">Student ID / Email</label>
                    <input type="text" name="username" placeholder="Enter ID" required>
                </div>
                <div class="input-group">
                    <label>Password</label>
                    <input type="password" name="password" placeholder="••••••••" required>
                </div>
                <button type="submit" class="btn-login">Secure Login</button>
            </form>
        </div>

        <div class="admission-box">
            <p>New to Green Valley School?</p>
            <a href="apply.php" class="btn-apply">Apply Now for Admission</a>
        </div>
    </div>
</div>

<script>
   function setRole(btn, role) {
    document.querySelectorAll('.role-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    
    // Change this line (fix the ID name):
    document.getElementById('user_type_hidden').value = role; 
    
    const displayRole = role.charAt(0).toUpperCase() + role.slice(1);
    document.getElementById('user-label').innerText = displayRole + ' ID / Email';
}

</script>

</body>
</html>
