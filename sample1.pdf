/* RESET */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: 'Segoe UI', sans-serif;
}

body {
  background: linear-gradient(135deg, #0f172a, #1e293b);
  color: #fff;
  overflow-x: hidden;
}

/* NAVBAR */
.navbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15px 8%;
  position: sticky;
  top: 0;
  z-index: 1000;

  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(15px);
  border-bottom: 1px solid rgba(255,255,255,0.1);
}

.navbar .logo {
  font-size: 22px;
  font-weight: bold;
}

.navbar nav a {
  color: white;
  margin-left: 20px;
  text-decoration: none;
  position: relative;
  transition: 0.3s;
}

.navbar nav a::after {
  content: "";
  position: absolute;
  width: 0%;
  height: 2px;
  left: 0;
  bottom: -4px;
  background: #38bdf8;
  transition: 0.3s;
}

.navbar nav a:hover::after {
  width: 100%;
}

/* HERO 1*/
.hero-section1 {
  text-align: center;
  padding: 100px 20px;
}

.hero-section1 h1 {
  font-size: 42px;
  margin-bottom: 20px;
}

.hero-section1 p {
  max-width: 600px;
  margin: auto;
  margin-bottom: 30px;
  opacity: 0.8;
} 

.btn-primary {
  padding: 12px 25px;
  border-radius: 30px;
  background: #38bdf8;
  color: black;
  text-decoration: none;
  transition: 0.3s;
}

.btn-primary:hover {
  background: #0ea5e9;
}

/* HERO 2 */
.hero-section {
  padding: 60px 8%;
}

.content-container {
  display: flex;
  align-items: center;
  gap: 40px;
  flex-wrap: wrap;
}

.text-content {
  flex: 1;
}

.text-content h1 {
  font-size: 36px;
  margin-bottom: 20px;
}

.email-form {
  margin-top: 20px;
}

.email-form input {
  padding: 10px;
  border-radius: 20px;
  border: none;
  outline: none;
  width: 60%;
}

.email-form button {
  padding: 10px 20px;
  border: none;
  border-radius: 20px;
  background: #38bdf8;
  margin-left: 10px;
  cursor: pointer;
}

.illustration-content img {
  width: 100%;
  max-width: 400px;
}

/* FEATURES */
.bg2 {
  padding: 60px 0;
}

.container {
  width: 90%;
  margin: auto;
}

.header-title {
  text-align: center;
  margin-bottom: 40px;
}

.features-grid {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
}

.feature-item {
  flex: 1;
  min-width: 250px;
  padding: 25px;
  border-radius: 15px;

  background: rgba(255,255,255,0.08);
  backdrop-filter: blur(10px);
  transition: 0.3s;
}

.feature-item:hover {
  transform: translateY(-8px);
}

.number-circle {
  width: 40px;
  height: 40px;
  background: #38bdf8;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10px;
}

/* FEATURE BOXES */
.features-section {
  display: flex;
  gap: 20px;
  margin-top: 40px;
  flex-wrap: wrap;
}

.feature-box {
  flex: 1;
  min-width: 250px;
  padding: 20px;
  border-radius: 15px;

  background: rgba(255,255,255,0.08);
  backdrop-filter: blur(10px);
  text-align: center;
  transition: 0.4s;
}

.feature-box:hover {
  transform: scale(1.05);
}

.image-box img {
  width: 100%;
  border-radius: 10px;
}

/* FAQ */
.faq-container {
  padding: 60px 8%;
}

.faq-item {
  margin-bottom: 10px;
  background: rgba(255,255,255,0.08);
  padding: 15px;
  border-radius: 10px;
}

/* FOOTER */
footer {
  text-align: center;
  padding: 20px;
  margin-top: 40px;
  opacity: 0.7;
}

/* ========================= */
/* ANIMATIONS (SAFE VERSION) */
/* ========================= */

.fade-in,
.slide-left,
.slide-right,
.zoom-in {
  opacity: 1;
  transition: all 0.8s ease;
}

/* JS ENABLED → hide first */
.js .fade-in,
.js .slide-left,
.js .slide-right,
.js .zoom-in {
  opacity: 0;
}

/* ANIMATION STATES */
.fade-in {
  transform: translateY(40px);
}
.fade-in.show {
  opacity: 1;
  transform: translateY(0);
}

.slide-left {
  transform: translateX(80px);
}
.slide-left.show {
  opacity: 1;
  transform: translateX(0);
}

.slide-right {
  transform: translateX(-80px);
}
.slide-right.show {
  opacity: 1;
  transform: translateX(0);
}

.zoom-in {
  transform: scale(0.8);
}
.zoom-in.show {
  opacity: 1;
  transform: scale(1);
}

/* ========================= */
/* RESPONSIVE */
/* ========================= */

@media (max-width: 768px) {
  .content-container {
    flex-direction: column;
    text-align: center;
  }

  .email-form input {
    width: 100%;
    margin-bottom: 10px;
  }

  .email-form button {
    width: 100%;
    margin-left: 0;
  }

  .navbar {
    flex-direction: column;
    gap: 10px;
  }

  .hero-section1 h1 {
    font-size: 28px;
  }
}

